# copy to .env and add your keys

# openai = real API calls, offline = local test mode (no keys needed)
LLM_BACKEND=offline

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROK_API_KEY=

# use one model for all roles if you don't have paid APIs
FREE_MODEL_MODE=true
FREE_MODEL_PROVIDER=openai

OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_MODEL=gemini-1.5-pro
GROK_MODEL=grok-2-latest

API_DELAY_SECONDS=1.0
MAX_RETRIES=3
TEMPERATURE=0.7
RANDOM_SEED=42
